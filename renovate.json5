{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":pinDevDependencies",
    "security:openssf-scorecard",
    ":dependencyDashboard",
    ":semanticCommits",
  ],

  // Use "deps" as semantic commit type for all Renovate PRs
  semanticCommitType: "deps",

  // Label all Renovate PRs
  labels: ["deps"],

  // Limit concurrent PRs to avoid overwhelming CI and reviewers
  prConcurrentLimit: 5,

  // Automerge all PRs after CI passes
  automerge: true,
  platformAutomerge: true,

  // Wait 7 days after publish before creating PRs to avoid compromised packages
  minimumReleaseAge: "7 days",

  // Vulnerability fix PRs should be created immediately and prioritized
  vulnerabilityAlerts: {
    enabled: true,
    addLabels: ["deps/security"],
    schedule: ["at any time"],
    assignees: ["nownabe"],
  },

  // Separate lockfile maintenance
  lockFileMaintenance: {
    enabled: true,
    schedule: ["before 6am on monday"],
  },

  packageRules: [
    // Semantic commit scope per manager
    {
      matchManagers: ["npm"],
      semanticCommitScope: "npm",
    },
    {
      matchManagers: ["github-actions"],
      semanticCommitScope: "github-actions",
    },
    {
      matchManagers: ["mise"],
      semanticCommitScope: "mise",
    },

    // Pin all dependencies for reproducible builds
    {
      matchManagers: ["npm"],
      rangeStrategy: "pin",
    },

    // Group all non-major production dependency updates
    {
      matchManagers: ["npm"],
      matchDepTypes: ["dependencies"],
      matchUpdateTypes: ["minor", "patch"],
      groupName: "npm production dependencies (non-major)",
      schedule: ["before 6am on monday"],
    },

    // Group all non-major dev dependency updates
    {
      matchManagers: ["npm"],
      matchDepTypes: ["devDependencies"],
      matchUpdateTypes: ["minor", "patch"],
      groupName: "npm dev dependencies (non-major)",
      schedule: ["before 6am on monday"],
    },

    // Major updates get individual PRs with a label for visibility
    {
      matchManagers: ["npm"],
      matchUpdateTypes: ["major"],
      addLabels: ["deps/major"],
      schedule: ["before 6am on monday"],
    },

    // GitHub Actions: group non-major, individual PRs for major
    {
      matchManagers: ["github-actions"],
      matchUpdateTypes: ["minor", "patch", "digest"],
      groupName: "github actions (non-major)",
      schedule: ["before 6am on monday"],
    },
    {
      matchManagers: ["github-actions"],
      matchUpdateTypes: ["major"],
      addLabels: ["deps/major"],
      schedule: ["before 6am on monday"],
    },

    // mise tool versions
    // Workaround: run `mise lock` after mise.toml updates until Renovate
    // natively supports mise lockfile maintenance (renovatebot/renovate#40568).
    {
      matchManagers: ["mise"],
      matchUpdateTypes: ["minor", "patch"],
      groupName: "mise tools (non-major)",
      schedule: ["before 6am on monday"],
      postUpgradeTasks: {
        commands: ["mise lock"],
        fileFilters: ["mise.lock"],
      },
    },
    {
      matchManagers: ["mise"],
      matchUpdateTypes: ["major"],
      addLabels: ["deps/major"],
      schedule: ["before 6am on monday"],
      postUpgradeTasks: {
        commands: ["mise lock"],
        fileFilters: ["mise.lock"],
      },
    },
  ],
}
