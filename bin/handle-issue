#!/usr/bin/env bun
/**
 * handle-issue: Orchestrate handling a GitHub issue end-to-end.
 *
 * Usage:
 *   bin/handle-issue <issue-number-or-url> [--review-agent codex|claude]
 *
 * Workflow:
 *   1. Create a git worktree for isolated development
 *   2. Spawn claude CLI to implement the issue
 *   3. Run review loop (codex or claude), fix issues
 *   4. Create PR and post review comment
 *   5. Wait for CI/review, fix if needed, repeat until approved
 *   6. Clean up the worktree
 *
 * Logs are written to logs/issue-<issue>/<log-type>.log
 */

import { parseArgs } from "util";
import { mkdirSync, readdirSync } from "fs";
import { appendFile } from "node:fs/promises";
import { resolve } from "path";
import { waitPr, type WaitPrResult } from "../tools/lib/wait-pr";
import type { CodeReviewResult, ReviewBackend } from "../tools/lib/review-schema";
import { codexReviewer } from "../tools/lib/review-by-codex";
import { claudeReviewer } from "../tools/lib/review-by-claude";

// ---------------------------------------------------------------------------
// CLI
// ---------------------------------------------------------------------------

const VALID_REVIEW_AGENTS = ["codex", "claude"] as const;
type ReviewAgent = (typeof VALID_REVIEW_AGENTS)[number];

const { values, positionals } = parseArgs({
  args: process.argv.slice(2),
  options: {
    "review-agent": { type: "string", default: "codex" },
  },
  allowPositionals: true,
});

const issueRef = positionals[0];
const reviewAgent = values["review-agent"] as ReviewAgent;

if (!issueRef || !VALID_REVIEW_AGENTS.includes(reviewAgent)) {
  console.error("Usage: bin/handle-issue <issue-number-or-url> [--review-agent codex|claude]");
  process.exit(1);
}

const reviewer: ReviewBackend = reviewAgent === "claude" ? claudeReviewer : codexReviewer;

// ---------------------------------------------------------------------------
// Constants
// ---------------------------------------------------------------------------

const MAX_REVIEW_ROUNDS = 5;
const MAX_CI_FIX_ROUNDS = 5;
const IMPLEMENT_TIMEOUT = 43_200_000; // 12h
const CLAUDE_TIMEOUT = 600_000; // 10min

// ---------------------------------------------------------------------------
// Logging
// ---------------------------------------------------------------------------

const projectRoot = resolve(import.meta.dirname, "..");
const issueSlug = issueRef.replace(/[^a-zA-Z0-9-]/g, "-");
const logDir = resolve(projectRoot, "logs", `issue-${issueSlug}`);
mkdirSync(logDir, { recursive: true });

async function writeLog(type: string, content: string) {
  await appendFile(resolve(logDir, `${type}.log`), content);
}

async function logLine(type: string, message: string) {
  await writeLog(type, `[${new Date().toISOString()}] ${message}\n`);
}

// Expose env vars so PreToolUse hook can auto-approve and log tools
process.env.GRAPHEIN_HANDLE_ISSUE = "1";
process.env.GRAPHEIN_HANDLE_ISSUE_LOG_DIR = logDir;

// ---------------------------------------------------------------------------
// Process runner
// ---------------------------------------------------------------------------

type RunOptions = {
  timeout?: number;
  cwd?: string;
  logType?: string;
  onSpawn?: (pid: number) => void;
};

type RunResult = {
  stdout: string;
  stderr: string;
  exitCode: number;
  pid: number;
};

async function run(cmd: string[], opts?: RunOptions): Promise<RunResult> {
  const cmdStr = cmd.join(" ");
  const logType = opts?.logType ?? "orchestrator";

  await logLine("orchestrator", `$ ${cmdStr}${opts?.cwd ? ` (cwd: ${opts.cwd})` : ""}`);

  const proc = Bun.spawn(cmd, {
    stdout: "pipe",
    stderr: "pipe",
    cwd: opts?.cwd,
    timeout: opts?.timeout,
  });
  await logLine("orchestrator", `pid=${proc.pid}`);
  opts?.onSpawn?.(proc.pid);

  const [stdout, stderr, exitCode] = await Promise.all([
    new Response(proc.stdout).text(),
    new Response(proc.stderr).text(),
    proc.exited,
  ]);

  await logLine("orchestrator", `exit=${exitCode} stdout=${stdout.length}B stderr=${stderr.length}B`);

  if (logType !== "orchestrator") {
    const header = `${"=".repeat(72)}\n[${new Date().toISOString()}] $ ${cmdStr}\nexit=${exitCode}\n${"=".repeat(72)}\n`;
    let entry = header;
    if (stdout) entry += `--- stdout ---\n${stdout}\n`;
    if (stderr) entry += `--- stderr ---\n${stderr}\n`;
    await writeLog(logType, entry);
  } else {
    if (stdout) await logLine("orchestrator", `stdout: ${stdout.slice(0, 500)}`);
    if (stderr) await logLine("orchestrator", `stderr: ${stderr.slice(0, 500)}`);
  }

  return { stdout: stdout.trim(), stderr: stderr.trim(), exitCode, pid: proc.pid };
}

// ---------------------------------------------------------------------------
// Claude session helpers
// ---------------------------------------------------------------------------

function claudeProjectDir(cwd: string): string | null {
  const home = process.env.HOME ?? "";
  const projectsDir = resolve(home, ".claude", "projects");
  const encoded = cwd.replaceAll("/", "-").replaceAll(".", "-");
  try {
    const entries = readdirSync(projectsDir);
    return entries.includes(encoded) ? resolve(projectsDir, encoded) : null;
  } catch {
    return null;
  }
}

function listSessionFiles(cwd: string): Set<string> {
  const dir = claudeProjectDir(cwd);
  if (!dir) return new Set();
  try {
    return new Set(readdirSync(dir).filter((f) => f.endsWith(".jsonl")));
  } catch {
    return new Set();
  }
}

async function detectNewSession(cwd: string, knownFiles: Set<string>): Promise<string | null> {
  for (let i = 0; i < 60; i++) {
    const dir = claudeProjectDir(cwd);
    if (dir) {
      try {
        const newFile = readdirSync(dir)
          .filter((f) => f.endsWith(".jsonl"))
          .find((f) => !knownFiles.has(f));
        if (newFile) {
          const sessionId = newFile.replace(".jsonl", "");
          console.log(`   Session ID: ${sessionId}`);
          console.log(`   Session file: ${resolve(dir, newFile)}`);
          return sessionId;
        }
      } catch {}
    }
    await Bun.sleep(500);
  }
  return null;
}

function printSessionInfo(sessionId: string, cwd: string) {
  console.log(`   Session ID: ${sessionId}`);
  const dir = claudeProjectDir(cwd);
  if (dir) {
    console.log(`   Session file: ${resolve(dir, `${sessionId}.jsonl`)}`);
  }
}

/** Run a claude CLI command in the worktree, resuming an existing session. */
async function claudeResume(
  prompt: string,
  sessionId: string,
  cwd: string,
  opts: { outputFormat?: "json" | "text"; logType: string },
): Promise<RunResult> {
  return run(
    ["claude", "-p", prompt, "--resume", sessionId, "--output-format", opts.outputFormat ?? "text"],
    {
      timeout: CLAUDE_TIMEOUT,
      cwd,
      logType: opts.logType,
      onSpawn: (pid) => {
        console.log(`   PID: ${pid}`);
        printSessionInfo(sessionId, cwd);
      },
    },
  );
}

// ---------------------------------------------------------------------------
// Utility
// ---------------------------------------------------------------------------

function extractPrUrl(text: string): string | null {
  return text.match(/https:\/\/github\.com\/[^/]+\/[^/]+\/pull\/\d+/)?.[0] ?? null;
}

function extractPrNumber(url: string): string {
  return url.split("/").pop()!;
}

function extractSessionId(jsonOutput: string): string | null {
  try {
    return JSON.parse(jsonOutput).session_id ?? null;
  } catch {
    return null;
  }
}

function extractResultText(jsonOutput: string): string {
  try {
    return JSON.parse(jsonOutput).result ?? "";
  } catch {
    return jsonOutput;
  }
}

async function postComment(prNumber: string, body: string): Promise<void> {
  await run([
    "bun", "run", "tools/comment-pr.ts", prNumber,
    "--posted-by", "bin/handle-issue",
    "--body", body,
  ]);
}

// ---------------------------------------------------------------------------
// Phase 1: Setup worktree
// ---------------------------------------------------------------------------

async function setupWorktree(): Promise<{ worktreePath: string; cleanup: () => Promise<void> }> {
  const worktreeName = `handle-issue-${issueRef.replace(/[^a-zA-Z0-9-]/g, "-")}`;
  const worktreeBase = `.agents/worktrees/${worktreeName}`;

  console.log(`\n🌳 Creating worktree: ${worktreeName}`);

  await run(["git", "fetch", "origin", "main"]);
  const addResult = await run(["git", "worktree", "add", "-b", worktreeName, worktreeBase, "origin/main"]);
  if (addResult.exitCode !== 0) {
    console.error(`❌ Failed to create worktree (see ${logDir}/orchestrator.log)`);
    process.exit(1);
  }

  const worktreePath = (await run(["git", "worktree", "list", "--porcelain"])).stdout
    .split("\n")
    .filter((line) => line.startsWith("worktree "))
    .map((line) => line.replace("worktree ", ""))
    .find((path) => path.includes(worktreeName));

  if (!worktreePath) {
    console.error(`❌ Could not resolve worktree path (see ${logDir}/orchestrator.log)`);
    process.exit(1);
  }

  console.log(`   Path: ${worktreePath}`);

  const cleanup = async () => {
    console.log(`\n🧹 Cleaning up worktree...`);
    await run(["git", "worktree", "remove", "--force", worktreePath]);
    await run(["git", "branch", "-D", worktreeName]);
  };

  return { worktreePath, cleanup };
}

// ---------------------------------------------------------------------------
// Phase 2: Implement
// ---------------------------------------------------------------------------

async function implement(worktreePath: string): Promise<string> {
  console.log(`\n📋 Implementing issue: ${issueRef}`);

  const prompt = [
    `Handle issue ${issueRef}`,
    "",
    "IMPORTANT: Do NOT create a pull request. Only implement the changes, run checks (bun run check:all), and commit.",
    "Do NOT use /pr skill or gh pr create.",
  ].join("\n");

  const knownSessions = listSessionFiles(worktreePath);
  let sessionDetection: Promise<string | null> | null = null;

  const result = await run(["claude", "-p", prompt, "--output-format", "json"], {
    timeout: IMPLEMENT_TIMEOUT,
    cwd: worktreePath,
    logType: "implement",
    onSpawn: (pid) => {
      console.log(`   PID: ${pid}`);
      sessionDetection = detectNewSession(worktreePath, knownSessions);
    },
  });

  await sessionDetection;

  if (result.exitCode !== 0) {
    console.error(`❌ Implementation failed (exit code: ${result.exitCode})`);
    console.error(`   See: ${logDir}/implement.log`);
    return "";
  }

  const sessionId = extractSessionId(result.stdout);
  if (!sessionId) {
    console.error("❌ Could not extract session ID from output");
    console.error(`   See: ${logDir}/implement.log`);
    return "";
  }

  return sessionId;
}

// ---------------------------------------------------------------------------
// Phase 3: Review
// ---------------------------------------------------------------------------

type ReviewRound = {
  round: number;
  review: CodeReviewResult;
  fixed: boolean;
};

async function runReviewLoop(worktreePath: string, sessionId: string): Promise<ReviewRound[]> {
  const rounds: ReviewRound[] = [];

  for (let n = 1; n <= MAX_REVIEW_ROUNDS; n++) {
    console.log(`\n🔍 ${reviewAgent} review round ${n}/${MAX_REVIEW_ROUNDS}...`);

    // Run review
    let review: CodeReviewResult;
    try {
      review = await reviewer.review({ cwd: worktreePath });
      await Bun.write(resolve(logDir, `review-${n}.json`), JSON.stringify(review, null, 2));
      await logLine("orchestrator", `review round=${n} status=${review.status} findings=${review.findings.length}`);
    } catch (err) {
      const errLog = `review-${n}.error.log`;
      await writeLog(errLog, String(err instanceof Error ? err.stack ?? err.message : err));
      console.error(`⚠️  ${reviewAgent} review failed, skipping. See: ${logDir}/${errLog}`);
      await logLine("orchestrator", `review round=${n} error=${err}`);
      break;
    }

    // Approved — done
    if (review.status === "approved") {
      console.log(`   ${reviewAgent} review: approved (no issues)`);
      rounds.push({ round: n, review, fixed: false });
      break;
    }

    // Changes requested — fix
    console.log(`   ${reviewAgent} review: ${review.findings.length} issue(s) found. Fixing...`);

    const fixPrompt = [
      `Code review (${reviewAgent}) found issues in the current changes. Fix them.`,
      "",
      `Findings:\n${JSON.stringify(review.findings, null, 2)}`,
      "",
      "Steps:",
      "1. Read each finding (check location.path and location.line)",
      "2. Make the appropriate code changes",
      "3. Run bun run check:all",
      "4. Commit the fixes",
    ].join("\n");

    const fixResult = await claudeResume(fixPrompt, sessionId, worktreePath, {
      logType: `review-fix-${n}`,
    });

    if (fixResult.exitCode !== 0) {
      console.error(`⚠️  Review fix failed, skipping. See: ${logDir}/review-fix-${n}.log`);
      rounds.push({ round: n, review, fixed: false });
      break;
    }

    rounds.push({ round: n, review, fixed: true });
    console.log(`   Review fixes applied (round ${n}).`);

    if (n === MAX_REVIEW_ROUNDS) {
      console.error(`⚠️  Review did not converge after ${MAX_REVIEW_ROUNDS} rounds.`);
    }
  }

  return rounds;
}

// ---------------------------------------------------------------------------
// Phase 4: Create PR
// ---------------------------------------------------------------------------

async function createPr(
  worktreePath: string,
  sessionId: string,
): Promise<{ prUrl: string; prNumber: string }> {
  console.log(`\n📤 Creating pull request...`);

  const prompt = [
    `Create a pull request for the changes you've made to handle issue ${issueRef}.`,
    "",
    "IMPORTANT: When creating the PR (step 5 of /pr skill), use subagent mode:",
    "only run `gh pr create`, do NOT run wait-pr.ts. Return the PR URL at the end of your response.",
  ].join("\n");

  const result = await claudeResume(prompt, sessionId, worktreePath, {
    outputFormat: "json",
    logType: "create-pr",
  });

  if (result.exitCode !== 0) {
    console.error(`❌ PR creation failed (exit code: ${result.exitCode})`);
    console.error(`   See: ${logDir}/create-pr.log`);
    return { prUrl: "", prNumber: "" };
  }

  const prUrl = extractPrUrl(extractResultText(result.stdout));
  if (!prUrl) {
    console.error("❌ Could not find PR URL in output");
    console.error(`   See: ${logDir}/create-pr.log`);
    return { prUrl: "", prNumber: "" };
  }

  const prNumber = extractPrNumber(prUrl);
  console.log(`\n✅ PR created: ${prUrl}`);
  console.log(`   Session: ${sessionId}`);

  return { prUrl, prNumber };
}

// ---------------------------------------------------------------------------
// Phase 4b: Post review comment
// ---------------------------------------------------------------------------

async function postReviewComment(prNumber: string, rounds: ReviewRound[]): Promise<void> {
  if (rounds.length === 0) return;

  const lastRound = rounds[rounds.length - 1];
  const approved = lastRound.review.status === "approved";
  const agentLabel = reviewAgent === "codex" ? "Codex" : "Claude";

  let body = `## ${agentLabel} Review\n\n`;

  if (approved && rounds.length === 1) {
    body += lastRound.review.comment_markdown;
  } else {
    body += approved
      ? `Approved after ${rounds.length} round(s).\n`
      : `Not fully resolved after ${rounds.length} round(s).\n`;

    for (const entry of rounds) {
      body += `\n### Round ${entry.round}`;
      if (entry.review.status === "approved") {
        body += ` — ✅ Approved\n\n${entry.review.comment_markdown}\n`;
      } else {
        const status = entry.fixed ? "🔧 Fixed" : "⚠️ Not fixed";
        body += ` — ${status}\n\n`;
        body += `${entry.review.summary}\n\n`;
        body += entry.review.findings
          .map(
            (f) =>
              `- **${f.severity}** (${f.category}): ${f.title} — \`${f.location.path}${f.location.line ? `:${f.location.line}` : ""}\``,
          )
          .join("\n");
        body += "\n";
      }
    }
  }

  await postComment(prNumber, body);
}

// ---------------------------------------------------------------------------
// Phase 5: Wait for CI/review and fix loop
// ---------------------------------------------------------------------------

async function waitAndFix(
  prUrl: string,
  prNumber: string,
  sessionId: string,
  worktreePath: string,
): Promise<void> {
  let waitSince = new Date();
  let round = 0;
  let ciFixCount = 0;

  while (true) {
    round++;

    // --- Poll until actionable ---
    const status = await pollUntilActionable(prNumber, waitSince, worktreePath, round);

    // --- Terminal states ---
    if (status.status === "approved") {
      console.log(`\n🎉 PR approved: ${prUrl}`);
      return;
    }
    if (status.status === "merged") {
      console.log(`\n🎉 PR merged: ${prUrl}`);
      return;
    }
    if (status.status === "closed") {
      console.log(`\n⚠️  PR was closed: ${prUrl}`);
      return;
    }

    // --- CI failure ---
    if (status.status === "ci_failed") {
      ciFixCount++;
      if (ciFixCount > MAX_CI_FIX_ROUNDS) {
        throw new Error(
          `CI did not pass after ${MAX_CI_FIX_ROUNDS} fix rounds. Manual intervention needed.\n   PR: ${prUrl}\n   Logs: ${logDir}/`,
        );
      }
      console.log(`\n🔧 CI failed. Fixing (CI fix ${ciFixCount}/${MAX_CI_FIX_ROUNDS})...`);
    }

    // --- Review feedback ---
    if (status.status === "has_feedback") {
      console.log(`\n💬 Review feedback received. Addressing (round ${round})...`);
      ciFixCount = 0;
    }

    // --- Fix ---
    const fixPrompt = buildFixPrompt(prUrl, status);
    const fixResult = await claudeResume(fixPrompt, sessionId, worktreePath, {
      logType: `fix-${round}`,
    });

    if (fixResult.exitCode !== 0) {
      throw new Error(`Fix round ${round} failed. See: ${logDir}/fix-${round}.log`);
    }

    waitSince = new Date();
    console.log(`   Fix round ${round} complete. Re-checking...`);
  }
}

async function pollUntilActionable(
  prNumber: string,
  since: Date,
  cwd: string,
  round: number,
): Promise<WaitPrResult> {
  console.log(`\n⏳ Waiting for CI/review (round ${round})...`);

  let pollCount = 0;
  const pollStartedAt = Date.now();

  while (true) {
    pollCount++;
    const status = await waitPr({ prNumber, since, cwd });
    await logLine("wait-pr", `status=${status.status} lgtm=${status.lgtm} ci=${status.ci.state} feedback=${status.feedback.length}`);

    if (status.status !== "pending") {
      if (pollCount > 1) process.stdout.write("\r\x1b[K");
      console.log(`   Status: ${status.status}`);
      return status;
    }

    const elapsed = Math.round((Date.now() - pollStartedAt) / 1000);
    const mins = Math.floor(elapsed / 60);
    const secs = elapsed % 60;
    const timeStr = mins > 0 ? `${mins}m${secs}s` : `${secs}s`;
    process.stdout.write(`\r\x1b[K   ⏳ Polling... (attempt ${pollCount}, elapsed ${timeStr})`);
  }
}

function buildFixPrompt(prUrl: string, status: WaitPrResult): string {
  if (status.status === "ci_failed") {
    return [
      `The PR ${prUrl} has CI failures. Fix them.`,
      "",
      `CI result JSON:\n${JSON.stringify(status, null, 2)}`,
      "",
      "Steps:",
      "1. Extract the run ID from failed check URLs (format: .../actions/runs/<run-id>/...)",
      "2. Get failure details: bunx @nownabe/claude-tools gh list-run-jobs <run-id> and bunx @nownabe/claude-tools gh get-job-logs <job-id>",
      "3. Fix the issues",
      "4. Run bun run check:all",
      "5. Commit and push (git push)",
    ].join("\n");
  }

  return [
    `The PR ${prUrl} has review feedback. Address it.`,
    "",
    `Feedback JSON:\n${JSON.stringify(status, null, 2)}`,
    "",
    "Steps:",
    "1. Read each feedback item (check path and line fields for review_comments)",
    "2. Make the appropriate code changes",
    "3. Run bun run check:all",
    "4. Commit and push (git push)",
  ].join("\n");
}

// ===========================================================================
// Main orchestration
// ===========================================================================

async function main() {
  console.log(`📝 Logs: ${logDir}/`);

  const { worktreePath, cleanup } = await setupWorktree();

  try {
    // Phase 2: Implement the issue
    const sessionId = await implement(worktreePath);
    if (!sessionId) {
      throw new Error("Implementation phase failed");
    }

    // Check if any changes were made (committed, staged, or untracked)
    const diffResult = await run(["git", "diff", "origin/main", "--quiet"], { cwd: worktreePath });
    const statusResult = await run(["git", "status", "--porcelain"], { cwd: worktreePath });
    if (diffResult.exitCode === 0 && statusResult.stdout === "") {
      console.log(`\nℹ️  No changes were made. The issue may already be resolved.`);
      return;
    }

    // Phase 3: Review loop (fix issues before PR)
    const reviewRounds = await runReviewLoop(worktreePath, sessionId);

    // Phase 4: Create PR
    const { prUrl, prNumber } = await createPr(worktreePath, sessionId);
    if (!prUrl) {
      throw new Error("PR creation failed");
    }

    // Phase 4b: Post review comment to PR
    await postReviewComment(prNumber, reviewRounds);

    // Phase 5: Wait for CI/review and fix
    await waitAndFix(prUrl, prNumber, sessionId, worktreePath);
  } finally {
    await cleanup();
  }
}

await main();
