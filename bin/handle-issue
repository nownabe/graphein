#!/usr/bin/env bun
/**
 * handle-issue: Orchestrate handling a GitHub issue end-to-end.
 *
 * Usage:
 *   bin/handle-issue <issue-number-or-url>
 *
 * This script controls the workflow deterministically:
 *   1. Create a git worktree for isolated development
 *   2. Spawn claude CLI to implement the issue (commit + push, no PR)
 *   3. If --codex-review: run Codex CLI review loop, fix issues before PR
 *   4. Resume claude session to create the PR
 *   5. Wait for CI/review (tools/wait-pr.ts)
 *   6. If fixes needed, resume the same claude session to fix
 *   7. Repeat 5-6 until approved or max retries
 *   8. Clean up the worktree
 *
 * Logs are written to logs/issue-<issue>/<log-type>.log
 *
 * The claude CLI uses all existing project assets (CLAUDE.md, hooks, skills, etc).
 */

import { parseArgs } from "util";
import { mkdirSync } from "fs";
import { resolve } from "path";

const MAX_FIX_ROUNDS = 5;

const { values, positionals } = parseArgs({
  args: process.argv.slice(2),
  options: {
    "codex-review": { type: "boolean", default: false },
  },
  allowPositionals: true,
});

const issueRef = positionals[0];
const enableCodexReview = values["codex-review"]!;

if (!issueRef) {
  console.error("Usage: bin/handle-issue <issue-number-or-url> [--codex-review]");
  process.exit(1);
}

// ---------------------------------------------------------------------------
// Logging
// ---------------------------------------------------------------------------

const projectRoot = resolve(import.meta.dirname, "..");
const issueSlug = issueRef.replace(/[^a-zA-Z0-9-]/g, "-");
const logDir = resolve(projectRoot, "logs", `issue-${issueSlug}`);
mkdirSync(logDir, { recursive: true });

/** Append to logs/issue-<N>/<type>.log */
async function writeLog(type: string, content: string) {
  const file = resolve(logDir, `${type}.log`);
  await Bun.write(file, content, { append: true });
}

async function logLine(type: string, message: string) {
  const line = `[${new Date().toISOString()}] ${message}\n`;
  await writeLog(type, line);
}

console.log(`📝 Logs: ${logDir}/`);

// ---------------------------------------------------------------------------
// helpers
// ---------------------------------------------------------------------------

async function run(
  cmd: string[],
  opts?: { timeout?: number; cwd?: string; logType?: string },
): Promise<{ stdout: string; stderr: string; exitCode: number }> {
  const cmdStr = cmd.join(" ");
  const logType = opts?.logType ?? "orchestrator";

  await logLine("orchestrator", `$ ${cmdStr}${opts?.cwd ? ` (cwd: ${opts.cwd})` : ""}`);

  const proc = Bun.spawn(cmd, {
    stdout: "pipe",
    stderr: "pipe",
    cwd: opts?.cwd,
    timeout: opts?.timeout,
  });
  const [stdout, stderr, exitCode] = await Promise.all([
    new Response(proc.stdout).text(),
    new Response(proc.stderr).text(),
    proc.exited,
  ]);

  await logLine("orchestrator", `exit=${exitCode} stdout=${stdout.length}B stderr=${stderr.length}B`);

  // Write detailed output to the specific log type
  if (logType !== "orchestrator") {
    const header = `${"=".repeat(72)}\n[${new Date().toISOString()}] $ ${cmdStr}\nexit=${exitCode}\n${"=".repeat(72)}\n`;
    let entry = header;
    if (stdout) entry += `--- stdout ---\n${stdout}\n`;
    if (stderr) entry += `--- stderr ---\n${stderr}\n`;
    await writeLog(logType, entry);
  } else {
    // Short commands: inline into orchestrator
    if (stdout) await logLine("orchestrator", `stdout: ${stdout.slice(0, 500)}`);
    if (stderr) await logLine("orchestrator", `stderr: ${stderr.slice(0, 500)}`);
  }

  return { stdout: stdout.trim(), stderr: stderr.trim(), exitCode };
}

function extractPrUrl(text: string): string | null {
  const match = text.match(/https:\/\/github\.com\/[^/]+\/[^/]+\/pull\/\d+/);
  return match ? match[0] : null;
}

function extractPrNumber(url: string): string {
  return url.split("/").pop()!;
}

function extractSessionId(jsonOutput: string): string | null {
  try {
    const result = JSON.parse(jsonOutput);
    return result.session_id ?? null;
  } catch {
    return null;
  }
}

// ---------------------------------------------------------------------------
// Codex review helper
// ---------------------------------------------------------------------------

type CodexReviewOutput = {
  schema_version: string;
  status: "approved" | "changes_requested";
  summary: string;
  comment_markdown: string;
  reviewed_ref: { base: string; head: string };
  findings: Array<{
    title: string;
    severity: "high" | "medium" | "low";
    category: string;
    description: string;
    suggested_fix: string | null;
    confidence: "high" | "medium" | "low";
    location: { path: string; line: number | null; end_line: number | null };
    snippet: string | null;
  }>;
};

async function runCodexReview(cwd: string, round: number): Promise<CodexReviewOutput | null> {
  console.log(`\n🔍 Running Codex CLI review...`);

  const outputFile = `${cwd}/.codex-review-output.tmp`;

  const codexResult = await run(
    [
      "codex",
      "exec",
      "--output-schema",
      "tools/codex-review-schema.json",
      "-s",
      "read-only",
      "-o",
      outputFile,
      "Review the code changes between origin/main and HEAD in this git repository. Identify bugs, security issues, or regressions. Be strict: only report concrete, actionable findings.",
    ],
    { timeout: 300_000, cwd, logType: `codex-review-${round}` },
  );

  if (codexResult.exitCode !== 0) {
    console.error("⚠️  Codex review failed (non-zero exit), skipping.");
    await run(["rm", "-f", outputFile], { cwd });
    return null;
  }

  try {
    const outputText = await Bun.file(outputFile).text();
    await run(["rm", "-f", outputFile], { cwd });

    // Save review JSON to log directory for debugging/auditing
    const reviewLogFile = resolve(logDir, `codex-review-${round}.json`);
    await Bun.write(reviewLogFile, outputText);
    console.log(`   Saved review output: ${reviewLogFile}`);

    return JSON.parse(outputText) as CodexReviewOutput;
  } catch {
    console.error("⚠️  Failed to parse Codex review output, skipping.");
    await run(["rm", "-f", outputFile], { cwd });
    return null;
  }
}

// ---------------------------------------------------------------------------
// Worktree setup
// ---------------------------------------------------------------------------

const worktreeName = `handle-issue-${issueRef.replace(/[^a-zA-Z0-9-]/g, "-")}`;
const worktreeBase = `../${worktreeName}`;

console.log(`\n🌳 Creating worktree: ${worktreeName}`);

await run(["git", "fetch", "origin", "main"]);
const addResult = await run([
  "git",
  "worktree",
  "add",
  "-b",
  worktreeName,
  worktreeBase,
  "origin/main",
]);
if (addResult.exitCode !== 0) {
  console.error(`❌ Failed to create worktree (see ${logDir}/orchestrator.log)`);
  process.exit(1);
}

// Resolve the absolute path of the worktree
const worktreePath = (await run(["git", "worktree", "list", "--porcelain"])).stdout
  .split("\n")
  .filter((line) => line.startsWith("worktree "))
  .map((line) => line.replace("worktree ", ""))
  .find((path) => path.includes(worktreeName));

if (!worktreePath) {
  console.error(`❌ Could not resolve worktree path (see ${logDir}/orchestrator.log)`);
  process.exit(1);
}

console.log(`   Path: ${worktreePath}`);

// Cleanup function
async function cleanup() {
  console.log(`\n🧹 Cleaning up worktree...`);
  await run(["git", "worktree", "remove", "--force", worktreePath]);
  await run(["git", "branch", "-D", worktreeName]);
}

// ---------------------------------------------------------------------------
// Phase 1: Implement (no PR yet)
// ---------------------------------------------------------------------------

console.log(`\n📋 Implementing issue: ${issueRef}`);

const implementResult = await run(
  [
    "claude",
    "-p",
    `Handle issue ${issueRef}\n\nIMPORTANT: Do NOT create a pull request and do NOT push. Only implement the changes and commit them locally. Do NOT run the /pr skill or git push. Return a summary of what you implemented at the end of your response.`,
    "--permission-mode",
    "bypassPermissions",
    "--output-format",
    "json",
  ],
  { timeout: 1_800_000, cwd: worktreePath, logType: "implement" },
);

if (implementResult.exitCode !== 0) {
  console.error(`❌ Implementation failed (exit code: ${implementResult.exitCode})`);
  console.error(`   See: ${logDir}/implement.log`);
  await cleanup();
  process.exit(1);
}

const sessionId = extractSessionId(implementResult.stdout);
if (!sessionId) {
  console.error("❌ Could not extract session ID from output");
  console.error(`   See: ${logDir}/implement.log`);
  await cleanup();
  process.exit(1);
}

console.log(`\n✅ Implementation complete.`);
console.log(`   Session: ${sessionId}`);

// ---------------------------------------------------------------------------
// Phase 2: Codex review (before PR creation)
// ---------------------------------------------------------------------------

if (enableCodexReview) {
  const MAX_CODEX_ROUNDS = 5;
  let codexApproved = false;

  for (let codexRound = 1; codexRound <= MAX_CODEX_ROUNDS; codexRound++) {
    console.log(`\n🔍 Codex review round ${codexRound}/${MAX_CODEX_ROUNDS}...`);

    const review = await runCodexReview(worktreePath, codexRound);

    if (!review) {
      console.error(`❌ Codex review failed. See: ${logDir}/codex-review-${codexRound}.log`);
      await cleanup();
      process.exit(1);
    }

    if (review.status === "approved") {
      console.log(`   Codex review: approved (no issues)`);
      codexApproved = true;
      break;
    }

    // changes_requested — fix and re-review (unless this is the last round)
    if (codexRound === MAX_CODEX_ROUNDS) {
      break;
    }

    console.log(`   Codex review: ${review.findings.length} issue(s) found. Fixing...`);

    const findingsJson = JSON.stringify(review.findings, null, 2);
    const fixPrompt = `Codex CLI review found issues in the code changes. Fix them.\n\nFindings:\n${findingsJson}\n\nSteps:\n1. Read each finding (check location.path and location.line)\n2. Make the appropriate code changes\n3. Run bun run check:all\n4. Commit locally (do NOT push)`;

    const fixResult = await run(
      [
        "claude",
        "-p",
        fixPrompt,
        "--resume",
        sessionId,
        "--permission-mode",
        "bypassPermissions",
        "--output-format",
        "text",
      ],
      { timeout: 600_000, cwd: worktreePath, logType: `codex-fix-${codexRound}` },
    );

    if (fixResult.exitCode !== 0) {
      console.error(`❌ Codex review fix failed. See: ${logDir}/codex-fix-${codexRound}.log`);
      await cleanup();
      process.exit(1);
    }

    console.log(`   Codex review fixes applied (round ${codexRound}).`);
  }

  if (!codexApproved) {
    console.error(`❌ Codex review did not converge after ${MAX_CODEX_ROUNDS} rounds. Aborting.`);
    await cleanup();
    process.exit(1);
  }
}

// ---------------------------------------------------------------------------
// Phase 3: Create PR
// ---------------------------------------------------------------------------

console.log(`\n📦 Creating PR...`);

// Ensure the branch is pushed with upstream tracking before PR creation
const pushResult = await run(
  ["git", "push", "--set-upstream", "origin", "HEAD"],
  { cwd: worktreePath },
);
if (pushResult.exitCode !== 0) {
  console.error(`❌ Failed to push branch. See: ${logDir}/orchestrator.log`);
  await cleanup();
  process.exit(1);
}

const createPrResult = await run(
  [
    "claude",
    "-p",
    `Create a pull request for issue ${issueRef}.\n\nIMPORTANT: When creating the PR (step 5 of /pr skill), use subagent mode:\nonly run \`gh pr create\`, do NOT run wait-pr.ts. Return the PR URL at the end of your response.`,
    "--resume",
    sessionId,
    "--permission-mode",
    "bypassPermissions",
    "--output-format",
    "json",
  ],
  { timeout: 600_000, cwd: worktreePath, logType: "create-pr" },
);

if (createPrResult.exitCode !== 0) {
  console.error(`❌ PR creation failed (exit code: ${createPrResult.exitCode})`);
  console.error(`   See: ${logDir}/create-pr.log`);
  await cleanup();
  process.exit(1);
}

// Extract PR URL from the result field in JSON output
let resultText: string;
try {
  resultText = JSON.parse(createPrResult.stdout).result ?? "";
} catch {
  resultText = createPrResult.stdout;
}

const prUrl = extractPrUrl(resultText);
if (!prUrl) {
  console.error("❌ Could not find PR URL in output");
  console.error(`   See: ${logDir}/create-pr.log`);
  await cleanup();
  process.exit(1);
}

const prNumber = extractPrNumber(prUrl);
console.log(`\n✅ PR created: ${prUrl}`);

// ---------------------------------------------------------------------------
// Phase 4: Wait and fix loop
// ---------------------------------------------------------------------------

for (let round = 1; round <= MAX_FIX_ROUNDS; round++) {
  console.log(`\n⏳ Waiting for CI/review (round ${round}/${MAX_FIX_ROUNDS})...`);

  // Keep polling until an actionable status is reached (no timeout limit).
  let status: any;

  while (true) {
    const waitResult = await run(
      ["bun", "run", "tools/wait-pr.ts", prNumber],
      { cwd: worktreePath, logType: "wait-pr" },
    );

    if (waitResult.exitCode !== 0) {
      console.error(`❌ wait-pr.ts failed. See: ${logDir}/wait-pr.log`);
      await cleanup();
      process.exit(1);
    }

    try {
      status = JSON.parse(waitResult.stdout);
    } catch {
      console.error(`❌ Failed to parse wait-pr.ts output. See: ${logDir}/wait-pr.log`);
      await cleanup();
      process.exit(1);
    }

    console.log(`   Status: ${status.status}`);

    if (status.status !== "pending") {
      break;
    }

    // pending — keep polling without consuming a fix round
    console.log(`   Still pending, re-polling...`);
  }

  if (status.status === "approved") {
    console.log(`\n🎉 PR approved: ${prUrl}`);
    await cleanup();
    process.exit(0);
  }

  if (status.status === "merged") {
    console.log(`\n🎉 PR merged: ${prUrl}`);
    await cleanup();
    process.exit(0);
  }

  if (status.status === "closed") {
    console.log(`\n⚠️  PR was closed: ${prUrl}`);
    await cleanup();
    process.exit(0);
  }

  // ci_failed or has_feedback — fix it
  if (status.status === "ci_failed") {
    console.log(`\n🔧 CI failed. Fixing (round ${round})...`);
  } else {
    console.log(`\n💬 Review feedback received. Addressing (round ${round})...`);
  }

  const fixPrompt =
    status.status === "ci_failed"
      ? `The PR ${prUrl} has CI failures. Fix them.\n\nCI result JSON:\n${JSON.stringify(status, null, 2)}\n\nSteps:\n1. Extract the run ID from failed check URLs (format: .../actions/runs/<run-id>/...)\n2. Get failure details: bunx @nownabe/claude-tools gh list-run-jobs <run-id> and bunx @nownabe/claude-tools gh get-job-logs <job-id>\n3. Fix the issues\n4. Run bun run check:all\n5. Commit and push (git push)`
      : `The PR ${prUrl} has review feedback. Address it.\n\nFeedback JSON:\n${JSON.stringify(status, null, 2)}\n\nSteps:\n1. Read each feedback item (check path and line fields for review_comments)\n2. Make the appropriate code changes\n3. Run bun run check:all\n4. Commit and push (git push)`;

  const fixResult = await run(
    [
      "claude",
      "-p",
      fixPrompt,
      "--resume",
      sessionId,
      "--permission-mode",
      "bypassPermissions",
      "--output-format",
      "text",
    ],
    { timeout: 600_000, cwd: worktreePath, logType: `fix-${round}` },
  );

  if (fixResult.exitCode !== 0) {
    console.error(`❌ Fix round ${round} failed. See: ${logDir}/fix-${round}.log`);
    await cleanup();
    process.exit(1);
  }

  console.log(`   Fix round ${round} complete. Re-checking...`);
}

console.error(
  `\n⚠️  Did not converge after ${MAX_FIX_ROUNDS} fix rounds. Manual intervention needed.`,
);
console.error(`   PR: ${prUrl}`);
console.error(`   Logs: ${logDir}/`);
await cleanup();
process.exit(1);
