{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(bun build:*)",
      "Bash(bun install:*)",
      "Bash(gh pr create:*)",
      "Bash(git switch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git reset:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(git worktree:*)",
      "Bash(git merge:*)",
      "Bash(git fetch:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(mise install:*)",
      "Bash(ghalint run:*)",
      "Bash(oxlint:*)",
      "Bash(oxfmt:*)",
      "Bash(bun run tools/run-sql.ts:*)",
      "mcp__chrome-devtools__*",
      "Skill(commit)",
      "Skill(pr)",
      "Skill(e2e)",
      "Skill(handle-issue)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cd $(jq -r .cwd) && mise trust 2>/dev/null || true'"
          }
        ]
      }
    ]
  }
}
