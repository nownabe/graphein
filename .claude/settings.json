{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(bun build:*)",
      "Bash(bun install:*)",
      "Bash(codex --help)",
      "Bash(gh issue create:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh run rerun:*)",
      "Bash(git switch:*)",
      "Bash(git add:*)",
      "Bash(git clean-squashed:*)",
      "Bash(git commit:*)",
      "Bash(git reset:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(git worktree:*)",
      "Bash(git merge:*)",
      "Bash(git fetch:*)",
      "Bash(git checkout:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git ls-tree:*)",
      "Bash(git mv:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git restore:*)",
      "Bash(git revert:*)",
      "Bash(git rm:*)",
      "Bash(git status:*)",
      "Bash(mise install:*)",
      "Bash(ghalint run:*)",
      "Bash(oxlint:*)",
      "Bash(oxfmt:*)",
      "Bash(bun run tools/run-sql.ts:*)",
      "Bash(bun run tools/wait-pr.ts:*)",
      "mcp__chrome-devtools__*",
      "Skill(review-by-claude)",
      "Skill(review-by-codex)",
      "Skill(commit)",
      "Skill(pr)",
      "Skill(e2e)",
      "Skill(handle-issue)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun tools/hooks/handle-issue-approve.ts"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cd $(jq -r .cwd) && mise trust 2>/dev/null || true'"
          }
        ]
      }
    ]
  }
}
