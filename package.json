{
  "name": "graphein",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "db:up": "docker compose up -d db db-test db-e2e",
    "db:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "css": "tailwindcss -i src/views/global.css -o public/styles.css --watch",
    "css:build": "tailwindcss -i src/views/global.css -o public/styles.css --minify",
    "test": "bun test",
    "test:tools": "bun test --test-root ./tools/lib",
    "test:integration": "bun test --test-root ./test/integration --preload ./test/integration/helpers/setup.ts --max-concurrency 1",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "check:all": "bun run check:app && bun run check:tools && bun run check:format && bun run check:lint && bun run check:workflows",
    "check:app": "bun run typecheck && bun run test && bun run test:integration && bun run css:build",
    "check:tools": "bun run test:tools",
    "check:format": "oxfmt --check",
    "check:lint": "oxlint --deny-warnings",
    "check:workflows": "actionlint && ghalint run && zizmor .github/workflows/",
    "slack:manifest": "bash scripts/generate-slack-manifest.sh",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@hono/mcp": "^0.2.5",
    "@hono/zod-openapi": "^1.2.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@scalar/hono-api-reference": "^0.10.7",
    "@slack/bolt": "^4.2.0",
    "@slack/web-api": "^7.9.0",
    "drizzle-orm": "^0.45.0",
    "hono": "^4.7.0",
    "hono-rate-limiter": "^0.5.3",
    "postgres": "^3.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@tailwindcss/cli": "4.2.4",
    "@types/bun": "1.3.13",
    "drizzle-kit": "0.31.10",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3"
  }
}
